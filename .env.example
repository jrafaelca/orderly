# App
NUXT_PUBLIC_APP_NAME=Orderly

# PostgreSQL (matches compose.yml host setup)
DB_HOST=127.0.0.1
DB_PORT=5433
DB_USER=orderly
DB_PASSWORD=password
DB_NAME=orderly
DB_SCHEMA=public
DB_MIGRATIONS_SCHEMA=drizzle
DB_MIGRATIONS_TABLE=__drizzle_migrations
# false | true | require | allow | prefer | verify-full
DB_SSL=false

# Optional single URL (if your runtime uses it)
DATABASE_URL=postgresql://orderly:password@127.0.0.1:5433/orderly

# Valkey / Redis-compatible URL
VALKEY_URL=redis://127.0.0.1:6379
REDIS_URL=redis://127.0.0.1:6379
